apiVersion: arcane.chezmoi.sh/v1alpha1
kind: ApplicationPatch
metadata: {}
spec:
  info:
    # -- Application metadata
    - name: Description
      value: >-
        Mutualized PostgreSQL clusters for lungmen.akn applications.
        Managed by the mutualized-cnpg-databases Helm chart.
        Two clusters: postgres-apps (for common applications)
        and postgres-apps-secured (for application requiring HA).
    - name: Category
      value: Database / Infrastructure
    # -- Documentation & Resources
    - name: Helm Chart
      value: catalog/helm/mutualized-cnpg-databases
    - name: GitHub Repository
      value: https://github.com/cloudnative-pg/cloudnative-pg

  syncPolicy:
    automated:
      # Automated sync is disabled for database infrastructure.
      # Schema migrations, role changes, and cluster config updates can cause
      # disruption if applied without human review. Sync manually via ArgoCD UI
      # or: argocd app sync databases
      enabled: false
