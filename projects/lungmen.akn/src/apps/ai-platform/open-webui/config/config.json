{
  "version": 0,
  "ui": {
    "default_locale": "en-US",
    "prompt_suggestions": [
      {
        "title": ["Help me study", "vocabulary for a college entrance exam"],
        "content": "Help me study vocabulary: write a sentence for me to fill in the blank, and I'll try to pick the correct option."
      },
      {
        "title": ["Give me ideas", "for what to do with my kids' art"],
        "content": "What are 5 creative things I could do with my kids' art? I don't want to throw them away, but it's also so much clutter."
      },
      {
        "title": ["Tell me a fun fact", "about the Roman Empire"],
        "content": "Tell me a random fun fact about the Roman Empire"
      },
      {
        "title": ["Show me a code snippet", "of a website's sticky header"],
        "content": "Show me a code snippet of a website's sticky header in CSS and JavaScript."
      }
    ],
    "enable_signup": true,
    "enable_login_form": false,
    "enable_community_sharing": true,
    "enable_message_rating": true,
    "default_user_role": "user"
  },
  "auth": {
    "enable_api_keys": false,
    "jwt_expiry": "4w"
  },
  "ollama": {
    "enable": false,
    "base_urls": []
  },
  "openai": {
    "enable": true,
    "api_base_urls": ["http://open-webui-pipelines.default.svc.cluster.local:9099", "http://192.168.10.30:1234"],
    "api_keys": [""],
    "api_configs": {}
  },
  "models": {
    "base_models_cache": false,
    "default_metadata": {},
    "default_params": {}
  },
  "rag": {
    "embedding_engine": "",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "embedding_batch_size": 1,
    "enable_async_embedding": true,
    "embedding_concurrent_requests": 0,
    "reranking_engine": "",
    "reranking_model": "",
    "top_k": 3,
    "top_k_reranker": 3,
    "relevance_threshold": 0.0,
    "hybrid_bm25_weight": 0.5,
    "enable_hybrid_search": false,
    "enable_hybrid_search_enriched_texts": false,
    "full_context": false,
    "chunk_size": 1000,
    "chunk_min_size_target": 0,
    "chunk_overlap": 100,
    "pdf_extract_images": false,
    "pdf_loader_mode": "page",
    "text_splitter": "",
    "enable_markdown_header_text_splitter": true,
    "tiktoken_encoding_name": "cl100k_base",
    "youtube_loader_language": ["en"],
    "youtube_loader_proxy_url": "",
    "CONTENT_EXTRACTION_ENGINE": "tika",
    "tika_server_url": "http://open-webui-tika:9998",
    "bypass_embedding_and_retrieval": false,
    "web": {
      "search": {
        "enable": true,
        "engine": "searxng",
        "result_count": 3,
        "concurrent_requests": 0,
        "domain": {
          "filter_list": []
        },
        "bypass_embedding_and_retrieval": false,
        "bypass_web_loader": false,
        "trust_env": false,
        "searxng_query_url": "http://searxng.ai-platform.svc.cluster.local:8080/search",
        "searxng_language": "all"
      },
      "loader": {
        "engine": "playwright",
        "concurrent_requests": 10,
        "timeout": "30000",
        "ssl_verification": true,
        "playwright_ws_url": "ws://playwright.ai-platform.svc.cluster.local:3000",
        "playwright_timeout": 30000
      }
    }
  },
  "image_generation": {
    "enable": false
  },
  "audio": {
    "stt": {
      "engine": "openai",
      "model": "openai/whisper-large-v3-turbo",
      "supported_content_types": [],
      "openai": {
        "api_base_url": "http://litellm.ai-platform.svc:4000/v1",
        "api_key": ""
      }
    },
    "tts": {
      "engine": "openai",
      "model": "hexgrad/kokoro",
      "voice": "ff_siwis",
      "split_on": "punctuation",
      "openai": {
        "api_base_url": "http://litellm.ai-platform.svc:4000/v1",
        "api_key": "",
        "params": {}
      }
    }
  },
  "code_execution": {
    "enable": true,
    "engine": "pyodide"
  },
  "code_interpreter": {
    "enable": true,
    "engine": "pyodide"
  },
  "memories": {
    "enable": true
  },
  "task": {
    "title": {
      "enable": true
    },
    "tags": {
      "enable": true
    },
    "follow_up": {
      "enable": true
    },
    "query": {
      "search": {
        "enable": true
      },
      "retrieval": {
        "enable": true
      }
    },
    "autocomplete": {
      "enable": false
    }
  },
  "user": {
    "permissions": {
      "workspace": {
        "models": true,
        "knowledge": true,
        "prompts": true,
        "tools": true,
        "skills": true
      },
      "chat": {
        "controls": true,
        "file_upload": true,
        "delete": true,
        "edit": true,
        "temporary": true
      },
      "features": {
        "web_search": true,
        "image_generation": true,
        "code_interpreter": true
      }
    }
  },
  "folders": {
    "enable": true
  },
  "channels": {
    "enable": false
  },
  "notes": {
    "enable": true
  }
}
