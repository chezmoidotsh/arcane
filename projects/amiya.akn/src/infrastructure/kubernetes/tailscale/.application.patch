apiVersion: arcane.chezmoi.sh/v1alpha1
kind: ApplicationPatch
metadata: {}
spec:
  info:
    # -- Application metadata
    - name: Description
      value: Tailscale Kubernetes operator for secure mesh networking
    - name: Category
      value: Networking / VPN
    - name: Version
      # renovate: datasource=helm depName=tailscale-operator registryUrl=https://pkgs.tailscale.com/helmcharts
      value: "1.98.3"
    # -- Documentation & Resources
    - name: Documentation
      value: https://tailscale.com/kb/1236/kubernetes-operator
    - name: Troubleshooting
      value: https://tailscale.com/kb/1236/kubernetes-operator/#troubleshooting
    - name: GitHub Repository
      value: https://github.com/tailscale/tailscale

  syncPolicy:
    automated:
      enabled: true

  # SOPS split: primary source is pre-rendered dist/, connector secret comes from src/sops/
  sources:
    - repoURL: https://github.com/chezmoidotsh/arcane.git
      path: "projects/amiya.akn/dist/infrastructure/kubernetes/tailscale"
      targetRevision: main
    - repoURL: https://github.com/chezmoidotsh/arcane.git
      path: "projects/amiya.akn/src/infrastructure/kubernetes/tailscale/sops"
      targetRevision: main