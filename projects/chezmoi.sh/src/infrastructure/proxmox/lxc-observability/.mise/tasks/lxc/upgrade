#!/usr/bin/env bash
# trunk-ignore-all(shellcheck/SC2029): SSH commands intentionally expand ${pve_host}, ${source_id}, ${target_id}, ${template_path}, ${mp0_mount} on the client; the values are local to this script, not on the remote PVE host.
# [MISE] description="Upgrade (or downgrade) the observability LXC to a specific image version"
# [USAGE] arg "<pve_host>" help="Hostname or IP of the Proxmox node (e.g. pve.lan)"
# [USAGE] arg "<source_id>" help="VMID of the running container whose config is copied"
# [USAGE] arg "<target_id>" help="VMID for the new container (must not already exist)"
# [USAGE] flag "-V --version <version>" help="Appliance image version (e.g. 2026.06.05) — auto-detected from flake if omitted"
# [USAGE] flag "-y --yes" help="Skip confirmation prompt"

set -euo pipefail

pve_host="${usage_pve_host}"
source_id="${usage_source_id}"
target_id="${usage_target_id}"
version="${usage_version-}"
yes="${usage_yes-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

# Container uid for the shared `victoria` user (configuration.nix: uid 980).
# Default Proxmox mapping: container uid N → host uid 100000 + N.
HOST_UID=100980

# --- Resolve version and template name -------------------------------------
if [[ -z ${version} ]]; then
  version="$(grep -m1 'version = "' "${CONFIG_ROOT}/flake.nix" |
    sed 's/.*version = "\(.*\)".*/\1/')"
  echo "[INFO] Auto-detected version: ${version}" >&2
fi
template="observability.${version}-amd64.tar.xz"
template_path="/var/lib/vz/template/cache/${template}"

# --- Verify template is present on the PVE host ----------------------------
echo "[>] ssh root@${pve_host} test -f '${template_path}'" >&2
if ! ssh "root@${pve_host}" "test -f '${template_path}'"; then
  echo "[ERROR] Template not found on ${pve_host}: ${template_path}" >&2
  echo "        Run 'mise run lxc:build && mise run lxc:push -- ${pve_host}' to upload it." >&2
  exit 1
fi

# --- Verify source exists; confirm with user --------------------------------
echo "[>] ssh root@${pve_host} cat /etc/pve/lxc/${source_id}.conf" >&2
source_conf=$(ssh "root@${pve_host}" "cat /etc/pve/lxc/${source_id}.conf 2>/dev/null" || true)
if [[ -z ${source_conf} ]]; then
  echo "[ERROR] CT ${source_id} does not exist on ${pve_host}." >&2
  exit 1
fi
source_hostname=$(echo "${source_conf}" | awk '/^hostname:/{print $2}')
echo "[INFO] Source: CT ${source_id} (${source_hostname})" >&2

if [[ -z ${yes} ]]; then
  read -r -p "[?] Upgrade CT ${source_id} (${source_hostname}) → CT ${target_id} using ${template}? [y/N] " confirm
  [[ ${confirm} =~ ^[Yy]$ ]] || {
    echo "[ABORTED]" >&2
    exit 1
  }
else
  echo "[INFO] Skipping confirmation (--yes)" >&2
fi

# --- Verify target does not exist ------------------------------------------
echo "[>] ssh root@${pve_host} cat /etc/pve/lxc/${target_id}.conf" >&2
target_conf=$(ssh "root@${pve_host}" "cat /etc/pve/lxc/${target_id}.conf 2>/dev/null" || true)
if [[ -n ${target_conf} ]]; then
  target_hostname=$(echo "${target_conf}" | awk '/^hostname:/{print $2}')
  echo "[ERROR] CT ${target_id} (${target_hostname}) already exists on ${pve_host}." >&2
  echo "        Choose a different VMID or destroy CT ${target_id} first." >&2
  exit 1
fi

# --- Parse rootfs and mp0 from source config --------------------------------
# Volume architecture:
#   rootfs  — NixOS system files; ephemeral, rebuilt from template on upgrade.
#   mp0     — persistent data (/var/lib/victoria); reattached to the new CT
#             as-is. No copy needed: the LVM thin volume follows the container.
rootfs_line=$(echo "${source_conf}" | grep '^rootfs:' | sed 's/^rootfs: //')
rootfs_storage=$(echo "${rootfs_line}" | cut -d: -f1)
rootfs_size=$(echo "${rootfs_line}" | grep -oE 'size=[0-9]+[GMKTgmkt]?' | cut -d= -f2 | tr -d 'GMKTgmkt')
source_rootfs_vol=$(echo "${rootfs_line}" | cut -d, -f1) # e.g. nvme-lvm:vm-100-disk-0

mp0_line=$(echo "${source_conf}" | grep '^mp0:' | sed 's/^mp0: //')
mp0_mount=$(echo "${mp0_line}" | grep -oE 'mp=[^,]+' | cut -d= -f2-)

echo "[INFO] rootfs: ${rootfs_storage}:${rootfs_size}G  mp0: reattach ${source_rootfs_vol%disk-0}disk-1 → ${mp0_mount}" >&2

# --- Create target container (fresh rootfs only; mp0 added below) -----------
# pct create allocates a new rootfs volume (vm-<target>-disk-0) and writes the
# template into it. We do NOT pass --mp0 here — the data volume is reattached
# from the source CT in the next step so no copy is needed.
echo "[INFO] Creating CT ${target_id} from ${template}..." >&2
echo "[>] ssh root@${pve_host} pct create ${target_id} ${template_path} --rootfs ${rootfs_storage}:${rootfs_size}" >&2
ssh "root@${pve_host}" \
  pct create "${target_id}" "${template_path}" \
  --rootfs "${rootfs_storage}:${rootfs_size}"

# --- Rewrite config: source settings + new rootfs vol + same mp0 vol --------
# Grab the new rootfs volume name that pct create just assigned.
new_rootfs_vol=$(ssh "root@${pve_host}" \
  "grep '^rootfs:' /etc/pve/lxc/${target_id}.conf | awk '{print \$2}' | cut -d, -f1")

echo "[INFO] Merging config: rootfs ${source_rootfs_vol} → ${new_rootfs_vol}, mp0 unchanged" >&2
echo "[>] ssh root@${pve_host} sed 's|${source_rootfs_vol}|${new_rootfs_vol}|g' /etc/pve/lxc/${source_id}.conf > /etc/pve/lxc/${target_id}.conf" >&2
ssh "root@${pve_host}" \
  "sed 's|${source_rootfs_vol}|${new_rootfs_vol}|g' /etc/pve/lxc/${source_id}.conf \
    > /etc/pve/lxc/${target_id}.conf"

# --- Copy firewall config ----------------------------------------------------
echo "[INFO] Copying firewall config from CT ${source_id} to CT ${target_id}..." >&2
echo "[>] ssh root@${pve_host} cp /etc/pve/firewall/${source_id}.fw /etc/pve/firewall/${target_id}.fw" >&2
ssh "root@${pve_host}" "
  if [[ -f /etc/pve/firewall/${source_id}.fw ]]; then
    cp /etc/pve/firewall/${source_id}.fw /etc/pve/firewall/${target_id}.fw
  else
    echo '[WARN] No firewall config found for CT ${source_id} — skipping.' >&2
  fi
"

# --- Fix data-volume ownership (uid map: container uid 980 → host 100980) --
echo "[INFO] Fixing ${mp0_mount} ownership (uid ${HOST_UID} = container victoria uid 980)..." >&2
echo "[>] ssh root@${pve_host} pct mount ${target_id} && chown -R ${HOST_UID}:${HOST_UID} /var/lib/lxc/${target_id}/rootfs${mp0_mount} && pct unmount ${target_id}" >&2
ssh "root@${pve_host}" "
  pct mount ${target_id}
  chown --recursive ${HOST_UID}:${HOST_UID} /var/lib/lxc/${target_id}/rootfs${mp0_mount}
  pct unmount ${target_id}
"

# --- Start the new container ------------------------------------------------
echo "[INFO] Starting CT ${target_id}..." >&2
echo "[>] ssh root@${pve_host} pct start ${target_id}" >&2
ssh "root@${pve_host}" pct start "${target_id}"

echo "" >&2
echo "✓  CT ${target_id} (${source_hostname}) is starting with ${template}" >&2
echo "" >&2
echo "Next steps:" >&2
echo "  1. Wait for Caddy TLS certificate:" >&2
echo "       ssh root@${pve_host} pct exec ${target_id} -- journalctl -u caddy -f" >&2
echo "  2. Verify ingest/query endpoint is responding:" >&2
echo "       curl -sSf https://o11y.chezmoi.sh/health" >&2
echo "  3. Cut over — stop the old container:" >&2
echo "       ssh root@${pve_host} pct stop ${source_id}" >&2
