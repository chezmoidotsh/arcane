#!/usr/bin/env bash
# [MISE] description="Upload the LXC template to Proxmox"
# [MISE] depends=["lxc:build"]
# [USAGE] arg "<pve_host>" help="Hostname or IP of the Proxmox node (e.g. pve.lan)"

set -euo pipefail

pve_host="${usage_pve_host}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
REPO_ROOT="$(git -C "${CONFIG_ROOT}" rev-parse --show-toplevel)"

ver=$(grep -m1 'version = "v' "${REPO_ROOT}/catalog/flakes/chezmoi.sh/zot/flake.nix" |
  grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
template="oci-proxy.${ver}-amd64.tar.xz"
src="${CONFIG_ROOT}/${template}"

[[ -f ${src} ]] ||
  {
    echo "[ERROR] ${src} not found — run 'mise run lxc:build' first" >&2
    exit 1
  }

echo "[INFO] Uploading ${template} to root@${pve_host}:/var/lib/vz/template/cache/..." >&2
scp "${src}" "root@${pve_host}:/var/lib/vz/template/cache/${template}"
echo "[SUCCESS] Template uploaded." >&2
