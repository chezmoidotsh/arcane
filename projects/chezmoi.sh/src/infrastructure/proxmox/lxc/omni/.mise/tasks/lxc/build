#!/usr/bin/env bash
# [MISE] description="Build the Omni LXC template with secrets baked in"
# [MISE] dir="{{config_root}}"

set -euo pipefail

source "$(pwd)/../.mise/lib/lxc.sh"

lxc_init "omni" "$(pwd)" _omni
lxc_secret "secrets/caddy.sops.env" CLOUDFLARE_API_TOKEN
lxc_secret "secrets/omni.sops.env" DEX_ADMIN_PASSWORD_HASH
lxc_build
