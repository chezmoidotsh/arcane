#!/usr/bin/env bash
# [MISE] description="Upload the Omni LXC template to Proxmox"
# [MISE] depends=["lxc:build"]
# [MISE] dir="{{config_root}}"
# [USAGE] arg "<pve_host>" help="Hostname or IP of the Proxmox node (e.g. pve.lan)"

set -euo pipefail

source "$(pwd)/../.mise/lib/lxc.sh"

lxc_init "omni" "$(pwd)" _omni
lxc_push "${usage_pve_host}"
