#!/usr/bin/env bash
# [MISE] description="Upload the omni-infra-provider-proxmox LXC template to Proxmox"
# [MISE] depends=["lxc:build"]
# [MISE] dir="{{config_root}}"
# [USAGE] arg "<pve_host>" help="Hostname or IP of the Proxmox node (e.g. pve.lan)"

set -euo pipefail

CONFIG_ROOT="$(pwd)"
# shellcheck source=../.mise/lib/lxc.sh
source "${CONFIG_ROOT}/../.mise/lib/lxc.sh"

lxc_init "omni-infra-provider-proxmox" "${CONFIG_ROOT}" _omni_proxmox_provider
lxc_push "${usage_pve_host}"
