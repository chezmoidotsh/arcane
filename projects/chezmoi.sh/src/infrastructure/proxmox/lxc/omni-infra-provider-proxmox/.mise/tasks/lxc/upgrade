#!/usr/bin/env bash
# trunk-ignore-all(shellcheck/SC2029): SSH commands intentionally expand local
# variables on the client.
# [MISE] description="Upgrade the omni-infra-provider-proxmox LXC to a new image version"
# [USAGE] arg "<pve_host>" help="Hostname or IP of the Proxmox node (e.g. pve.lan)"
# [USAGE] arg "<source_id>" help="VMID of the running container"
# [USAGE] flag "-t --target-id <target_id>" help="VMID for the new container (auto-picked starting at 100 if omitted)"
# [USAGE] flag "-V --version <version>" help="CalVer version — auto-detected from flake.nix if omitted"
# [USAGE] flag "-y --yes" help="Skip confirmation prompts"

set -euo pipefail

pve_host="${usage_pve_host}"
source_id="${usage_source_id}"
target_id="${usage_target_id-}"
version="${usage_version-}"
yes="${usage_yes-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

# --- Resolve version and template -------------------------------------------
if [[ -z ${version} ]]; then
  version=$(grep -m1 'version = "' "${CONFIG_ROOT}/flake.nix" |
    sed 's/.*version = "\(.*\)".*/\1/')
  echo "[INFO] Auto-detected version: ${version}" >&2
fi
template="omni-infra-provider-proxmox.${version}-amd64.tar.xz"
template_path="/var/lib/vz/template/cache/${template}"

# --- Resolve target VMID (auto-pick first free ≥ 100 if not given) ----------
if [[ -z ${target_id} ]]; then
  echo "[INFO] No --target-id given; picking the first free VMID ≥ 100..." >&2
  used=$(ssh "root@${pve_host}" "pct list | awk 'NR>1 {print \$1}'; \
    ls /etc/pve/qemu-server/ 2>/dev/null | sed 's/\\.conf$//'")
  candidate=100
  while echo "${used}" | grep -qx "${candidate}"; do
    candidate=$((candidate + 1))
  done
  target_id="${candidate}"
  echo "[INFO] Auto-picked target VMID: ${target_id}" >&2
fi

# ============================================================================
# Step 1 — Pre-flight checks
# ============================================================================
echo "===== Step 1 — Pre-flight checks =====" >&2

if ! ssh "root@${pve_host}" "test -f '${template_path}'"; then
  echo "[ERROR] Template not found on ${pve_host}: ${template_path}" >&2
  echo "        Run 'mise run lxc:build && mise run lxc:push -- ${pve_host}' to upload it." >&2
  exit 1
fi
echo "[OK] Template present: ${template}" >&2

source_conf=$(ssh "root@${pve_host}" "cat /etc/pve/lxc/${source_id}.conf 2>/dev/null" || true)
if [[ -z ${source_conf} ]]; then
  echo "[ERROR] CT ${source_id} does not exist on ${pve_host}." >&2
  exit 1
fi
source_hostname=$(echo "${source_conf}" | awk '/^hostname:/{print $2}')
echo "[OK] Source: CT ${source_id} (${source_hostname})" >&2

target_conf=$(ssh "root@${pve_host}" "cat /etc/pve/lxc/${target_id}.conf 2>/dev/null" || true)
if [[ -n ${target_conf} ]]; then
  echo "[ERROR] CT ${target_id} already exists on ${pve_host}. Destroy it first or choose another VMID." >&2
  exit 1
fi
echo "[OK] Target VMID ${target_id} is free" >&2

if [[ -z ${yes} ]]; then
  read -r -p "[?] Upgrade CT ${source_id} (${source_hostname}) → CT ${target_id} using ${template}? [y/N] " confirm
  [[ ${confirm} =~ ^[Yy]$ ]] || {
    echo "[ABORTED]" >&2
    exit 1
  }
fi

# ============================================================================
# Step 2 — Create target CT from new template
# ============================================================================
echo "===== Step 2 — Create target CT =====" >&2

ssh "root@${pve_host}" "
ROOTFS_LINE=\$(grep '^rootfs:' /etc/pve/lxc/${source_id}.conf | sed 's/^rootfs: //')
ROOTFS_STORAGE=\$(echo \"\$ROOTFS_LINE\" | cut -d: -f1)
ROOTFS_SIZE=\$(echo \"\$ROOTFS_LINE\" | grep -oE 'size=[0-9]+' | cut -d= -f2)
FEATURES=\$(grep '^features:' /etc/pve/lxc/${source_id}.conf | sed 's/^features: //')
MEMORY=\$(grep '^memory:' /etc/pve/lxc/${source_id}.conf | awk '{print \$2}')
CORES=\$(grep '^cores:' /etc/pve/lxc/${source_id}.conf | awk '{print \$2}')

pct create ${target_id} ${template_path} \
  --rootfs \$ROOTFS_STORAGE:\$ROOTFS_SIZE \
  --features \"\$FEATURES\" \
  --memory \$MEMORY \
  --cores \$CORES \
  --swap 0
"
echo "[OK] Target CT ${target_id} created" >&2

# ============================================================================
# Step 3 — Smoke-test the new template
# ============================================================================
echo "===== Step 3 — Smoke-test =====" >&2

ssh "root@${pve_host}" "pct start ${target_id}"
sleep 10

activation=$(ssh "root@${pve_host}" "pct exec ${target_id} -- /bin/sh -c 'test -e /run/current-system && echo OK || echo FAIL'")
if [[ ${activation} != *"OK"* ]]; then
  echo "[ERROR] Stage-2 activation failed — is features:nesting=1 set?" >&2
  ssh "root@${pve_host}" "pct stop ${target_id}" 2>/dev/null || true
  exit 1
fi
echo "[OK] NixOS activation passed" >&2

ssh "root@${pve_host}" "pct stop ${target_id}"

# ============================================================================
# Step 4 — Merge source config into target (preserve network + features)
# ============================================================================
echo "===== Step 4 — Merge config =====" >&2

ssh "root@${pve_host}" "
NEW_ROOTFS_VOL=\$(grep '^rootfs:' /etc/pve/lxc/${target_id}.conf | awk '{print \$2}' | cut -d, -f1)
OLD_ROOTFS_VOL=\$(grep '^rootfs:' /etc/pve/lxc/${source_id}.conf | sed 's/^rootfs: //' | cut -d, -f1)
sed \"s|\$OLD_ROOTFS_VOL|\$NEW_ROOTFS_VOL|g\" /etc/pve/lxc/${source_id}.conf > /etc/pve/lxc/${target_id}.conf
"

ssh "root@${pve_host}" "
if [[ -f /etc/pve/firewall/${source_id}.fw ]]; then
  cp /etc/pve/firewall/${source_id}.fw /etc/pve/firewall/${target_id}.fw
fi
"
echo "[OK] Config merged" >&2

# ============================================================================
# Step 5 — Cutover (downtime starts)
# ============================================================================
if [[ -z ${yes} ]]; then
  read -r -p "[?] Ready to cut over (CT ${source_id} will stop)? [y/N] " confirm
  [[ ${confirm} =~ ^[Yy]$ ]] || {
    echo "[ABORTED] Target ready but not started." >&2
    exit 0
  }
fi

echo "===== Step 5 — Cutover =====" >&2
T0=$(date +%s)

ssh "root@${pve_host}" "
pct stop ${source_id}
pct start ${target_id}
"
echo "[OK] Cutover: $(($(date +%s) - T0))s — service warming up" >&2

# ============================================================================
# Step 6 — Verify health
# ============================================================================
echo "===== Step 6 — Verify health (10s warm-up) =====" >&2
sleep 10

ssh "root@${pve_host}" "pct exec ${target_id} -- /run/current-system/sw/bin/bash -lc '
echo === system ===
systemctl is-system-running
systemctl --failed --no-legend
echo === provider ===
systemctl is-active omni-infra-provider-proxmox
'" >&2

# ============================================================================
# Step 7 — Decommission or rollback
# ============================================================================
if [[ -z ${yes} ]]; then
  read -r -p "[?] CT ${target_id} is working correctly? [y/N] " confirm
else
  confirm="y"
fi

if [[ ${confirm} =~ ^[Yy]$ ]]; then
  echo "===== Step 7 — Decommission CT ${source_id} =====" >&2
  ssh "root@${pve_host}" "
sed -i '/^rootfs:/d; /^unused0:/d' /etc/pve/lxc/${source_id}.conf
pct destroy ${source_id}
"
  echo "[OK] Upgrade complete. CT ${target_id} (${source_hostname}) is live." >&2
else
  echo "[WARN] Rolling back — restarting CT ${source_id}..." >&2
  ssh "root@${pve_host}" "
pct stop ${target_id}
pct start ${source_id}
"
  echo "[OK] Rolled back to CT ${source_id}." >&2
  echo "  Destroy the failed target:" >&2
  echo "    ssh root@${pve_host} \"sed -i '/^unused0:/d' /etc/pve/lxc/${target_id}.conf && pct destroy ${target_id}\"" >&2
  exit 1
fi
