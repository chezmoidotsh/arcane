#!/usr/bin/env bash
# [MISE] description="Build the omni-infra-provider-proxmox LXC template with secrets baked in"
# [MISE] dir="{{config_root}}"

set -euo pipefail

source "$(pwd)/../.mise/lib/lxc.sh"

lxc_init "omni-infra-provider-proxmox" "$(pwd)" _omni_proxmox_provider
lxc_secret "secrets/proxmox.sops.env" PROXMOX_PASSWORD
lxc_secret_optional "secrets/omni.sops.env" OMNI_SERVICE_ACCOUNT_KEY
lxc_build
