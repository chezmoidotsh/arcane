#!/usr/bin/env bash
# [MISE] description="Build the oci-registry LXC template with Cloudflare token baked in"
# [MISE] dir="{{config_root}}"

set -euo pipefail

CONFIG_ROOT="$(pwd)"
# shellcheck source=../.mise/lib/lxc.sh
source "${CONFIG_ROOT}/../.mise/lib/lxc.sh"

lxc_init "oci-registry" "${CONFIG_ROOT}" _oci_registry
lxc_secret "secrets/caddy.sops.env" CLOUDFLARE_API_TOKEN
lxc_build
