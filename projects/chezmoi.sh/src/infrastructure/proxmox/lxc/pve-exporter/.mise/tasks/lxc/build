#!/usr/bin/env bash
# [MISE] description="Build the pve-exporter LXC template with secrets baked in"
# [MISE] dir="{{config_root}}"

set -euo pipefail

CONFIG_ROOT="$(pwd)"
# shellcheck source=/dev/null
source "${CONFIG_ROOT}/../.mise/lib/lxc.sh"

lxc_init "pve-exporter" "${CONFIG_ROOT}" _pve_exporter
lxc_secret "secrets/pve-exporter.sops.env" PVE_HOST PVE_TOKEN_VALUE
lxc_build
