#!/usr/bin/env bash
# [MISE] description="Build the observability LXC template with all secrets baked in"
# [MISE] dir="{{config_root}}"

set -euo pipefail

source "$(pwd)/../.mise/lib/lxc.sh"

lxc_init "observability" "$(pwd)" _o11y
lxc_secret "secrets/caddy.sops.env" CLOUDFLARE_API_TOKEN TAILSCALE_OAUTH_KEY
lxc_secret "secrets/observability.sops.env" SLACK_WEBHOOK_URL ALERTMANAGER_DEADMAN_URL
lxc_build
