# .editorconfig - Global configuration for the "arcane" repository
# https://editorconfig.org

root = true

# Default rules for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# Markdown and text files
[*.{md,markdown,txt,adoc,asciidoc}]
trim_trailing_whitespace = false
max_line_length = off

[README.md]
trim_trailing_whitespace = false

# Shell scripts and environment files
[*.{sh,env}]
indent_style = space
indent_size = 2

# YAML files (indentation sensitive)
[*.{yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# JSON files
[*.json]
indent_style = space
indent_size = 2
insert_final_newline = false

# JavaScript / TypeScript / frontend
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# CSS / SCSS / LESS / HTML / XML
[*.{css,scss,less,html,xml}]
indent_style = space
indent_size = 2

# Python files (PEP8 follows 4 spaces)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# Go files (gofmt uses tabs)
[*.go]
indent_style = tab

# Makefiles (require tabs for recipes)
[Makefile]
indent_style = tab
trim_trailing_whitespace = false

# Dockerfiles
[Dockerfile]
indent_style = space
indent_size = 2

# Configuration files
[*.{toml,ini,conf,cnf}]
indent_style = space
indent_size = 2

# Minified files
[*.min.js]
trim_trailing_whitespace = false
insert_final_newline = false

# Binary and image files
[*.{png,jpg,jpeg,gif,webp,ico,zip,tar.gz,exe,dll,lock,sqlite}]
trim_trailing_whitespace = false
insert_final_newline = false
