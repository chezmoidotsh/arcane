{
	"compilerOptions": {
		// Output
		"outDir": "bin",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"stripInternal": true,
		// Environment
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"moduleDetection": "force",
		"types": ["node"],
		// Type Checking
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"files": [
		"acl.ts",
		"apiToken.ts",
		"config/index.ts",
		"config/vars.ts",
		"datastore.ts",
		"getDatastore.ts",
		"getDatastores.ts",
		"getMetricsServer.ts",
		"getMetricsServers.ts",
		"getNamespaces.ts",
		"getNotificationEndpoint.ts",
		"getNotificationEndpoints.ts",
		"getNotificationMatcher.ts",
		"getNotificationMatchers.ts",
		"getPruneJob.ts",
		"getPruneJobs.ts",
		"getRemoteGroups.ts",
		"getRemoteNamespaces.ts",
		"getRemoteStores.ts",
		"getS3Endpoint.ts",
		"getS3Endpoints.ts",
		"getSyncJob.ts",
		"getSyncJobs.ts",
		"getVerifyJob.ts",
		"getVerifyJobs.ts",
		"gotifyNotification.ts",
		"index.ts",
		"metricsServer.ts",
		"namespace.ts",
		"notificationMatcher.ts",
		"provider.ts",
		"pruneJob.ts",
		"remote.ts",
		"s3endpoint.ts",
		"sendmailNotification.ts",
		"smtpNotification.ts",
		"syncJob.ts",
		"types/index.ts",
		"types/input.ts",
		"types/output.ts",
		"user.ts",
		"utilities.ts",
		"verifyJob.ts",
		"webhookNotification.ts"
	]
}
