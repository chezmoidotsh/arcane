#!/usr/bin/env bash
# trunk-ignore-all(shellcheck/SC2312): don't care about masking return value
set -euo pipefail

# shellcheck source=nix:_lib
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)/nix:_lib"

show_usage() {
  cat <<EOF
Usage: $(basename "$0") [--load] [--no-sandbox] [--system <platform>] [--platforms] <path-to-flake-dir>

Options:
  --load              Automatically load the built image into Docker
  --no-sandbox        Disable Nix sandbox for the build (useful in certain CI environments)
  --system <platform> Force a specific platform (e.g., x86_64-linux, aarch64-linux)
  --platforms         Show available platforms for the flake and exit

Examples:
  $(basename "$0") catalog/flakes/hashicorp/vault
  $(basename "$0") --load catalog/flakes/openbao/openbao
  $(basename "$0") --system aarch64-linux catalog/flakes/openbao/openbao
  $(basename "$0") --load --system x86_64-linux catalog/flakes/hashicorp/vault
  $(basename "$0") --platforms catalog/flakes/hashicorp/vault
EOF
}

LOAD_IMAGE=false
FLAKE_DIR=""
TARGET_SYSTEM=""
SHOW_PLATFORMS=false
USE_SANDBOX=true

while [[ $# -gt 0 ]]; do
  case $1 in
  --load)
    LOAD_IMAGE=true
    shift
    ;;
  --no-sandbox)
    USE_SANDBOX=false
    shift
    ;;
  --system)
    if [[ -n ${2-} && $2 != -* ]]; then
      TARGET_SYSTEM="$2"
      shift 2
    else
      log_error "Option --system requires a platform argument."
      show_usage
      exit 1
    fi
    ;;
  --platforms)
    SHOW_PLATFORMS=true
    shift
    ;;
  -*)
    log_error "Unknown option: $1"
    show_usage
    exit 1
    ;;
  *)
    if [[ -z ${FLAKE_DIR} ]]; then
      FLAKE_DIR="$1"
    else
      log_error "Multiple flake directories specified."
      show_usage
      exit 1
    fi
    shift
    ;;
  esac
done

if [[ -z ${FLAKE_DIR} ]]; then
  show_usage
  exit 1
fi

if [[ ! -d ${FLAKE_DIR} || ! -f "${FLAKE_DIR}/flake.nix" ]]; then
  log_error "Flake directory '${FLAKE_DIR}' or '${FLAKE_DIR}/flake.nix' not found."
  exit 1
fi

_nix_resolve_flake_dir "${FLAKE_DIR}"

if [[ ${SHOW_PLATFORMS} == true ]]; then
  log_info "Inspecting flake at '${FLAKE_DIR}' for available platforms..."
  docker run --rm \
    -v "${REPO_ROOT}:/src" \
    -w "/src/${RELATIVE_FLAKE_PATH:-.}" \
    nixos/nix sh -c '
      rm -rf /homeless-shelter
      nix --extra-experimental-features "nix-command flakes" flake show --all-systems 2>/dev/null
    '
  exit 0
fi

_nix_ensure_volumes
_nix_tty_flags

OUTPUT_TAR="${FLAKE_DIR}/result"
log_info "Cleaning last build result..."
[[ -f ${OUTPUT_TAR} ]] && rm -f "${OUTPUT_TAR}"

log_info "Building flake from '${FLAKE_DIR}'${TARGET_SYSTEM:+ (platform: ${TARGET_SYSTEM})}..."

# We mount the entire repository into the container at /src.
# The working directory is set to the specific flake location within /src
# so Nix can access git context and use self.lastModifiedDate.
docker run --rm \
  -v "${NIX_CACHE_VOLUME}:/nix" \
  -v "${NIX_TOOLS_VOLUME}:/tools" \
  -v "${REPO_ROOT}:/src" \
  -w "/src/${RELATIVE_FLAKE_PATH:-.}" \
  ${DOCKER_TTY_FLAGS[@]+"${DOCKER_TTY_FLAGS[@]}"} \
  -e USE_SANDBOX="${USE_SANDBOX}" \
  -e TARGET_SYSTEM="${TARGET_SYSTEM}" \
  nixos/nix sh -c '
    set -euo pipefail
    rm -rf /homeless-shelter

    SANDBOX_FLAG=""
    [[ "${USE_SANDBOX:-true}" == "false" ]] && SANDBOX_FLAG="--option sandbox false"

    SYSTEM_ARG=""
    [[ -n "${TARGET_SYSTEM}" ]] && SYSTEM_ARG="--system ${TARGET_SYSTEM}"

    if [[ -x /tools/bin/nom ]]; then
        /tools/bin/nom build --extra-experimental-features "nix-command flakes" ${SANDBOX_FLAG} ${SYSTEM_ARG} --show-trace .#default --out-link result
    else
        nix --extra-experimental-features "nix-command flakes" build ${SANDBOX_FLAG} ${SYSTEM_ARG} --show-trace .#default --out-link result
    fi

    # Dereference the symlink so the result lands as a plain file on the host mount.
    if [[ -L result ]]; then
        mv result symlink_result
        cp -L symlink_result result
        rm symlink_result
    fi
  '

log_success "Image tarball is ready at '${OUTPUT_TAR}'."

if [[ ${LOAD_IMAGE} == true ]]; then
  log_info "Loading image into Docker..."
  if docker load <"${OUTPUT_TAR}"; then
    log_success "Image successfully loaded into Docker!"
    log_info "Available images:"
    docker images --filter "reference=*$(basename "${FLAKE_DIR}")*" \
      --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}\t{{.CreatedAt}}" | tail -n +2 || true
  else
    log_error "Failed to load image into Docker."
    exit 1
  fi
else
  log_info "To load into Docker, run: docker load < ${OUTPUT_TAR}"
  log_info "Or use the --load flag: $(basename "$0") --load ${FLAKE_DIR}"
fi
