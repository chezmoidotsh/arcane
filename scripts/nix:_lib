# Shared library for nix:* scripts — source this file, do not execute directly.
# Guard against double-sourcing.
[[ -n ${_NIX_LIB_LOADED:-} ]] && return 0
readonly _NIX_LIB_LOADED=1

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

readonly NIX_CACHE_VOLUME="nix-store-cache"
readonly NIX_TOOLS_VOLUME="nix-tools-cache"

log_info()    { echo -e "${BLUE}[INFO]${NC} $*" >&2; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $*" >&2; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $*" >&2; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# Sets REPO_ROOT, RELATIVE_FLAKE_PATH (no trailing slash), and
# WORKTREE_FLAKE_OVERLAY from a flake directory.
#
# In a git worktree, REPO_ROOT is set to the main repository root (not the
# worktree root) so Docker receives a directory with a real .git directory
# rather than a .git file whose absolute path is unreachable inside the Docker
# sandbox. WORKTREE_FLAKE_OVERLAY holds the absolute flake path on disk so
# callers can bind-mount the worktree-modified files over the main-branch copy.
_nix_resolve_flake_dir() {
  local flake_dir="$1"
  WORKTREE_FLAKE_OVERLAY=""
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local git_common_dir
    git_common_dir="$(git rev-parse --git-common-dir)"
    if [[ "${git_common_dir}" == /* ]]; then
      # Git worktree: git-common-dir is an absolute path to the main .git dir.
      REPO_ROOT="$(dirname "${git_common_dir}")"
      WORKTREE_ROOT="$(git rev-parse --show-toplevel)"
      WORKTREE_FLAKE_OVERLAY="$(cd "${flake_dir}" && pwd -P)"
    else
      REPO_ROOT="$(git rev-parse --show-toplevel)"
      WORKTREE_ROOT=""
    fi
    RELATIVE_FLAKE_PATH="$(cd "${flake_dir}" && git rev-parse --show-prefix)"
  else
    REPO_ROOT="$(cd "${flake_dir}" && pwd)"
    RELATIVE_FLAKE_PATH=""
  fi
  RELATIVE_FLAKE_PATH="${RELATIVE_FLAKE_PATH%/}"
}

# Ensures Docker cache volumes exist and nix-output-monitor is installed in the tools volume.
# Uses docker volume inspect (fast, no container) to decide whether nom needs installing.
_nix_ensure_volumes() {
  docker volume create "${NIX_CACHE_VOLUME}" >/dev/null

  local needs_nom=false
  docker volume inspect "${NIX_TOOLS_VOLUME}" >/dev/null 2>&1 || needs_nom=true
  docker volume create "${NIX_TOOLS_VOLUME}" >/dev/null

  if [[ ${needs_nom} == true ]]; then
    log_info "Installing nix-output-monitor in tools cache (first time only)..."
    docker run --rm \
      -v "${NIX_CACHE_VOLUME}:/nix" \
      -v "${NIX_TOOLS_VOLUME}:/tools" \
      nixos/nix sh -c '
        nix --extra-experimental-features "nix-command flakes" build nixpkgs#nix-output-monitor --out-link /tmp/nom-build
        mkdir -p /tools/bin
        cp -L /tmp/nom-build/bin/nom /tools/bin/
        chmod +x /tools/bin/nom
      '
  fi
}

# Populates DOCKER_TTY_FLAGS based on whether stdin/stdout are ttys.
#
# Implementation note: returning the exit status of `[[ -t 1 ]]` would make
# `set -e` callers exit silently whenever stdout is not a tty (mise tasks,
# CI pipelines, piped invocations). The explicit `return 0` decouples the
# function's success from the tty probe's boolean answer.
_nix_tty_flags() {
  DOCKER_TTY_FLAGS=()
  [[ -t 0 ]] && DOCKER_TTY_FLAGS+=(-i)
  [[ -t 1 ]] && DOCKER_TTY_FLAGS+=(-t)
  return 0
}
